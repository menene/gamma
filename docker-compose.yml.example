services:
  db:
    image: postgres:16
    environment:
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB: ${DB_NAME}
    ports:
      - "5432:5432"
    volumes:
      - dbdata:/var/lib/postgresql/data
      - ./db/init:/docker-entrypoint-initdb.d
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}"]
      interval: 5s
      timeout: 5s
      retries: 5

  api:
    build: ./api
    env_file: .env
    depends_on:
      db:
        condition: service_healthy
    ports:
      - "8000:8000"
    volumes:
      - ./api/app:/app/app

  lab:
    build: ./lab
    user: root
    environment:
      JUPYTER_TOKEN: ${JUPYTER_TOKEN}
      NB_UID: 1000
      NB_GID: 1000
      GRANT_SUDO: "yes"
    volumes:
      - ./lab/notebooks:/home/jovyan/work
      - ./lab/data:/home/jovyan/work/data
    ports:
      - "8888:8888"

  frontend:
    build:
      context: ./frontend
      args:
        FRONTEND_MODE: ${FRONTEND_MODE:-development}
    depends_on:
      - api
      - lab
    ports:
      - "8080:80"
    volumes:
      - ./frontend/src:/app/src
      - ./frontend/public:/app/public
      - ./frontend/index.html:/app/index.html
      - ./frontend/vite.config.ts:/app/vite.config.ts
      - ./frontend/nginx.conf:/app/nginx.conf

  planka:
    image: ghcr.io/plankanban/planka:latest
    depends_on:
      planka-db:
        condition: service_healthy
    environment:
      BASE_URL: ${PLANKA_URL:-http://localhost:3000}
      SECRET_KEY: ${PLANKA_SECRET}
      DEFAULT_ADMIN_EMAIL: ${PLANKA_ADMIN_EMAIL}
      DEFAULT_ADMIN_PASSWORD: ${PLANKA_ADMIN_PASSWORD}
      DEFAULT_ADMIN_NAME: Admin
      DEFAULT_ADMIN_USERNAME: admin
      DATABASE_URL: postgresql://planka:planka@planka-db:5432/planka
    ports:
      - "3000:1337"
    volumes:
      - planka-avatars:/app/public/user-avatars
      - planka-attachments:/app/private/attachments

  planka-db:
    image: postgres:16
    environment:
      POSTGRES_DB: planka
      POSTGRES_USER: planka
      POSTGRES_PASSWORD: planka
    volumes:
      - planka-dbdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U planka -d planka"]
      interval: 5s
      timeout: 5s
      retries: 5

volumes:
  dbdata:
  planka-dbdata:
  planka-avatars:
  planka-attachments:
